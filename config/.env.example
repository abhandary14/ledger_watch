# LedgerWatch Environment Configuration
# Copy this file to config/.env and fill in values before running locally.
# NEVER commit config/.env to version control.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=ledgerwatch
DB_USER=ledger
DB_PASSWORD=ledger
DB_HOST=postgres
DB_PORT=5432
