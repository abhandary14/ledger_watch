# LedgerWatch Environment Configuration
# Copy this file to config/.env and fill in values before running locally.
# NEVER commit config/.env to version control.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=ledgerwatch
DB_USER=ledger
DB_PASSWORD=ledger
DB_HOST=postgres
DB_PORT=5432

# Anthropic Claude API
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Report output directory (relative to BASE_DIR or absolute)
REPORT_OUTPUT_DIR=reports
